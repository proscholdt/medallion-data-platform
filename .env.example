STORAGE_ACCOUNT_NAME=your_storage_account
STORAGE_ACCOUNT_KEY=your_storage_account_key
FILE_SYSTEM_NAME=silver
X_API_Key=your_orion_api_key

# =============================================
# Pipedrive CRM
# =============================================
PD_API_URL=https://api.pipedrive.com/v1
PD_API_KEY=your_pipedrive_api_key

# =============================================
# Facebook Ads & Graph API
# =============================================
FB_AD_ACCOUNT_ID=act_your_ad_account_id
